{
  "name": "std-game-jigsaw-sample",
  "version": "0.1.0",
  "license": "ISC",
  "build": {
    "target": "macos-app",
    "executable": "DoofJigsaw",
    "title": "Doof Jigsaw",
    "icon": "images/generated_jigsaw_atlas.png",
    "resources": ["images"],
    "macosApp": {
      "bundleId": "dev.doof.jigsaw",
      "category": "public.app-category.games"
    },
    "iosApp": {
      "bundleId": "extremebasic.jigsaw",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Doof Jigsaw connects to a local puzzle server on your network.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "minimumDeploymentTarget": "16.0"
    },
    "native": {
      "extraCopyPaths": [
        "native_jigsaw.hpp"
      ],
      "sourceFiles": [
        "native_jigsaw.mm"
      ],
      "frameworks": [
        "CoreGraphics",
        "Foundation",
        "ImageIO"
      ],
      "macos": {
        "frameworks": [
          "AppKit"
        ]
      }
    }
  },
  "dependencies": {
  }
}
